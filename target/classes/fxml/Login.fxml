<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.library.controller.LoginController"
      alignment="CENTER" spacing="18"
      styleClass="login-root"
      prefWidth="480" prefHeight="360">

    <padding><Insets top="50" right="60" bottom="50" left="60"/></padding>

    <Label text="Library Management System" styleClass="login-title"/>
    <Label text="UE23CS352B — Design Patterns Demo" styleClass="login-subtitle"/>

    <Region prefHeight="10"/>

    <GridPane hgap="12" vgap="12" alignment="CENTER">
        <columnConstraints>
            <ColumnConstraints minWidth="90"/>
            <ColumnConstraints minWidth="200"/>
        </columnConstraints>

        <Label text="Your Name:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <TextField fx:id="nameField" promptText="Enter your name"
                   GridPane.columnIndex="1" GridPane.rowIndex="0"/>

        <Label text="Role:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <ComboBox fx:id="roleCombo" prefWidth="200"
                  GridPane.columnIndex="1" GridPane.rowIndex="1"/>
    </GridPane>

    <Label fx:id="errorLabel" styleClass="label-danger" text=""/>

    <Button text="Enter System" onAction="#handleLogin"
            styleClass="btn,btn-primary" prefWidth="200"/>

    <Label text="Design Patterns: Singleton · Factory · Facade · Observer"
           styleClass="login-footer"/>
</VBox>
